  <exec_depend>ur5e_social_motion</exec_depend>
  <exec_depend>social_robot_perception</exec_depend>
  <exec_depend>social_robot_hri</exec_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>